# -----------------------------------------------------------------------------
# AlbumApp — variáveis de ambiente (copie para .env e preencha)
# -----------------------------------------------------------------------------
# As vars EXPO_PUBLIC_* são injetadas no bundle em tempo de build pelo Expo.
# NÃO coloque segredos aqui (anon key do Supabase é pública por design).
# -----------------------------------------------------------------------------

# Supabase — pegue em: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui

# (opcional) Flask local — só usado se as vars do Supabase não estiverem setadas
EXPO_PUBLIC_FLASK_URL=http://192.168.0.216:5000
